# Copy this file to .env and fill in your Supabase project's values.
# Find these in your Supabase project: Settings -> API.

# Set to 'true' to run entirely against localStorage instead of Supabase -
# useful for local dev/preview without a Supabase project. When true, the
# VITE_SUPABASE_* vars below are ignored.
VITE_USE_LOCAL_DATA=false

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
